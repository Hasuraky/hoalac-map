# Copy file này thành .env.local rồi điền thông tin

# --- Supabase (Project Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Khóa bí mật server — dùng cho quản lý tài khoản & data tư vấn.
# KHÔNG có tiền tố NEXT_PUBLIC, chỉ đặt trên server (Vercel), không lộ ra trình duyệt.
SUPABASE_SERVICE_ROLE_KEY=

# --- Bản đồ Goong (account.goong.io > Keys > Maptiles key) ---
NEXT_PUBLIC_GOONG_MAPTILES_KEY=
